#!/usr/bin/env bash
# kindlectl —— Kindle Dashboard 服务管理 (开机自启 / 启停 / 状态)
#
#   kindlectl enable    安装开机自启 (Windows 计划任务, 登录时无窗口启动) 并立即启动
#   kindlectl disable   停止并卸载开机自启
#   kindlectl start      立即后台启动 (不影响开机自启设置)
#   kindlectl stop       优雅停止 (会推送告别屏)
#   kindlectl restart    重启
#   kindlectl status     查看运行 / 自启状态
#   kindlectl log        跟踪日志 (tail -f)
#
# 机制: 常驻的是 WSL 里的 python 循环 (kindle_dash.py), 用 pidfile 单实例.
# 开机自启 = 用户「启动」文件夹放隐藏 VBS(登录触发)→ wsl.exe 后台跑 python (免管理员).
set -euo pipefail

# ---- 读取集中配置 (机器相关项都在 config.sh) ----
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=config.sh
source "$HERE/config.sh"

SCRIPT="$PROJECT_DIR/kindle_dash.py"
LOG="/tmp/kindle_dash.log"
PIDFILE="/tmp/kindle_dash.pid"
STARTUP="/mnt/c/Users/$WIN_USER/AppData/Roaming/Microsoft/Windows/Start Menu/Programs/Startup"
VBS="$STARTUP/launch_kindle_dash.vbs"

# ---- 工具函数 ----
running_pid() {
    [[ -f "$PIDFILE" ]] || return 1
    local pid; pid=$(cat "$PIDFILE" 2>/dev/null) || return 1
    [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null && { echo "$pid"; return 0; }
    return 1
}

write_vbs() {
    # 隐藏窗口(第2参 0)、不等待(第3参 False)地后台启动 wsl 跑 python.
    cat > "$VBS" <<EOF
' KindleDash 隐藏启动器 —— 由 kindlectl 生成, 勿手改
CreateObject("WScript.Shell").Run "wsl.exe -d $DISTRO -u $WSL_USER -- bash -lc ""exec python3 -u $SCRIPT $DASH_ARGS >> $LOG 2>&1""", 0, False
EOF
    echo "  已写入启动文件夹: launch_kindle_dash.vbs"
}

do_start() {
    if pid=$(running_pid); then
        echo "已在运行 (pid $pid)"; return 0
    fi
    echo "启动中…"
    setsid python3 -u "$SCRIPT" $DASH_ARGS >> "$LOG" 2>&1 < /dev/null &
    sleep 1
    if pid=$(running_pid); then echo "已启动 (pid $pid), 日志: $LOG"
    else echo "启动失败, 看日志: $LOG" >&2; return 1; fi
}

do_stop() {
    if ! pid=$(running_pid); then echo "未在运行"; return 0; fi
    echo "停止中 (pid $pid), 推送告别屏…"
    kill -TERM "$pid"
    for _ in $(seq 1 60); do
        kill -0 "$pid" 2>/dev/null || { echo "已停止"; return 0; }
        sleep 0.5
    done
    echo "超时未退出, 强杀"; kill -KILL "$pid" 2>/dev/null || true
}

# ---- 子命令 ----
case "${1:-}" in
enable)
    echo "注册开机自启 (用户启动文件夹, 登录时触发)…"
    write_vbs
    echo "  下次登录自动启动 (墙面机若自动登录则≈开机即起)"
    do_start
    ;;
disable)
    do_stop || true
    echo "卸载开机自启…"
    rm -f "$VBS" && echo "  已从启动文件夹移除"
    ;;
start)   do_start ;;
stop)    do_stop ;;
restart) do_stop || true; sleep 1; do_start ;;
status)
    if pid=$(running_pid); then echo "运行中: 是 (pid $pid)"; else echo "运行中: 否"; fi
    if [[ -f "$VBS" ]]; then echo "开机自启: 已启用 (启动文件夹)"
    else echo "开机自启: 未启用"; fi
    ;;
log) tail -f "$LOG" ;;
*)
    grep '^#' "$0" | sed 's/^# \{0,1\}//' | head -20
    exit 1
    ;;
esac
